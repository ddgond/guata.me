---
// Shared markup, styles, and script loader for the find-on-map quizzes.
// The behavior lives in the <map-quiz> element (map-quiz.ts); the quiz prop
// picks a definition registered in map-quiz-defs.ts. Use the KabupatenQuiz /
// AreaCodeQuiz wrappers in posts rather than this component directly.
//
// quiz         — definition key ("kabupaten", "area-us", ...)
// scope        — passed through to the definition's scope-dependent hooks
// initial      — picker preselection (ignored without a picker)
// pickerLabel  — aria-label for the scope picker; omit to render no picker
// labelsToggle — render the Labels tile toggle (quizzes where map labels are
//                part of the drill)
// fontPicker   — render the Font picker (quizzes whose definition lists
//                typeface choices for the prompted names)
// find         — render the Find input (highlight matching shapes while
//                exploring the map; the definition's findMatch hook decides
//                what matches, defaulting to area-code wildcard patterns)
// findPlaceholder — example text shown in the empty Find input

interface Props {
	quiz: string;
	scope?: string;
	initial?: string;
	pickerLabel?: string;
	labelsToggle?: boolean;
	fontPicker?: boolean;
	find?: boolean;
	findPlaceholder?: string;
}

const {
	quiz,
	scope,
	initial,
	pickerLabel,
	labelsToggle = false,
	fontPicker = false,
	find = false,
	findPlaceholder = '9**',
} = Astro.props;

// The Find input is sized to its placeholder (never narrower than the
// area-code default), with CJK glyphs counted double — they render about
// two columns wide, so "札幌" needs ~4ch, not 2
const findWidth = Math.max(
	6,
	[...findPlaceholder].reduce((width, ch) => width + (ch.charCodeAt(0) > 0x2e7f ? 2 : 1), 1),
);
---

<map-quiz data-quiz={quiz} data-scope={scope} data-initial={initial}>
	<div class="bar top">
		{
			/* The {null} child keeps Prettier from collapsing this to a
			   self-closing <select />, which trips an @astrojs/compiler bug that
			   scrambles the closing tags of everything after it */
			pickerLabel && (
				<select class="picker" aria-label={pickerLabel}>
					{null}
				</select>
			)
		}
		<div class="top-actions">
			<span class="hf-transport" hidden>
				<button class="hf-pause" aria-label="Pause" title="Pause">
					<svg class="icon-pause" viewBox="0 0 16 16" aria-hidden="true">
						<rect x="4.2" y="3.5" width="2.6" height="9" rx="0.8" fill="currentColor"></rect>
						<rect x="9.2" y="3.5" width="2.6" height="9" rx="0.8" fill="currentColor"></rect>
					</svg>
					<svg class="icon-play" viewBox="0 0 16 16" aria-hidden="true">
						<path d="M5.5 3.4 L12.7 8 L5.5 12.6 Z" fill="currentColor"></path>
					</svg>
				</button>
				<button class="hf-skip" aria-label="Skip" title="Skip">
					<svg viewBox="0 0 16 16" aria-hidden="true">
						<path d="M3.8 3.6 L10 8 L3.8 12.4 Z" fill="currentColor"></path>
						<rect x="10.8" y="3.6" width="1.9" height="8.8" rx="0.7" fill="currentColor"></rect>
					</svg>
				</button>
				<button class="hf-stop" aria-label="Stop" title="Stop">
					<svg viewBox="0 0 16 16" aria-hidden="true">
						<rect x="4" y="4" width="8" height="8" rx="1.2" fill="currentColor"></rect>
					</svg>
				</button>
			</span>
			<button class="start" disabled>Start Quiz</button>
			<button class="hf-btn" aria-label="Hands-free mode" title="Hands-free mode" disabled>
				<svg viewBox="0 0 16 16" aria-hidden="true">
					<path
						d="M13.5 8 A5.5 5.5 0 1 1 11.9 4.1"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"></path>
					<path
						d="M11.6 2.2 L11.9 4.1 L10 3.8"
						fill="none"
						stroke="currentColor"
						stroke-width="1.2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
					<path
						d="M5.9 10.9 L8 5 L10.1 10.9 M6.7 9.1 L9.3 9.1"
						fill="none"
						stroke="currentColor"
						stroke-width="1.4"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</button>
		</div>
	</div>
	<div class="bar status" aria-live="polite">loading map…</div>
	<div class="map-wrap">
		<div class="map"></div>
		<div class="name-tip" hidden></div>
		<div class="overlay progress-overlay" hidden>
			<div class="dialog" role="dialog" aria-modal="true" aria-label="Progress">
				<div class="dialog-head">
					<strong>Progress</strong>
					<button class="close" aria-label="Close">✕</button>
				</div>
				<div class="table-wrap">
					<table class="progress-table"></table>
				</div>
			</div>
		</div>
		<div class="overlay confirm-overlay" hidden>
			<div class="dialog" role="dialog" aria-modal="true" aria-label="Confirm map option change">
				<p>Changing map options voids progress tracking for this quiz run.</p>
				<label class="dont-ask"
					><input type="checkbox" class="dont-ask-box" /> Don't ask me again</label
				>
				<div class="dialog-actions">
					<button class="cancel">Cancel</button>
					<button class="confirm">Continue</button>
				</div>
			</div>
		</div>
	</div>
	<div class="bar options">
		<label><input type="checkbox" class="borders" checked /> Borders</label>
		{
			labelsToggle && (
				<label>
					<input type="checkbox" class="labels" /> Labels
				</label>
			)
		}
		{
			fontPicker && (
				<label>
					Font:
					<select class="font-picker">{null}</select>
				</label>
			)
		}
		{
			find && (
				<label>
					Find:
					<input
						class="find"
						type="text"
						placeholder={findPlaceholder}
						style={`width: ${findWidth}ch`}
						autocomplete="off"
						spellcheck="false"
					/>
				</label>
			)
		}
		<div class="hf-controls" hidden>
			<div class="hf-stepper" data-dur="prompt">
				<span class="hf-label">Prompt</span>
				<span class="hf-row">
					<button class="hf-dec" aria-label="Shorter prompt time">‹</button>
					<span class="hf-value">5s</span>
					<button class="hf-inc" aria-label="Longer prompt time">›</button>
				</span>
			</div>
			<div class="hf-stepper" data-dur="zoom">
				<span class="hf-label">Zoom</span>
				<span class="hf-row">
					<button class="hf-dec" aria-label="Shorter zoom time">‹</button>
					<span class="hf-value">2s</span>
					<button class="hf-inc" aria-label="Longer zoom time">›</button>
				</span>
			</div>
			<div class="hf-stepper" data-dur="linger">
				<span class="hf-label">Linger</span>
				<span class="hf-row">
					<button class="hf-dec" aria-label="Shorter linger time">‹</button>
					<span class="hf-value">4s</span>
					<button class="hf-inc" aria-label="Longer linger time">›</button>
				</span>
			</div>
		</div>
		<button class="progress-btn">View Progress</button>
	</div>
</map-quiz>

<script>
	import './map-quiz-defs';
</script>

<style>
	map-quiz {
		display: block;
		/* Bleed out of the article column: full viewport width minus a small
		   gutter (which also absorbs the scrollbar), capped so it doesn't grow
		   comically wide beyond a MacBook Pro screen */
		--bleed: min(100vw - 2rem, 1700px);
		width: var(--bleed);
		margin-block: 1.5rem;
		margin-inline: calc(50% - var(--bleed) / 2);
		border: 1px solid var(--line);
		border-radius: 6px;
		overflow: hidden;
	}
	.map-wrap {
		position: relative;
	}
	.map {
		height: 65vh;
		height: 65svh; /* small-viewport unit: stable when mobile URL bars show/hide */
		background: #a2daf2;
	}
	/* Shorten Leaflet's 0.25s zoom transition — panning is locked while it runs */
	map-quiz :global(.leaflet-zoom-anim .leaflet-zoom-animated) {
		transition-duration: 0.05s;
	}
	.name-tip {
		position: absolute;
		z-index: 700; /* above Leaflet's overlay panes */
		padding: 0.1em 0.45em;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 4px;
		font-size: 0.85rem;
		pointer-events: none;
		white-space: nowrap;
	}
	.bar {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		padding: 0.5rem 0.8rem;
		font-size: 0.9rem;
	}
	.bar.top {
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
	}
	.bar.options {
		/* The Font picker can overflow a phone-width row; View Progress's auto
		   margin keeps it right-aligned on whichever line it wraps to */
		flex-wrap: wrap;
		border-top: 1px solid var(--line);
		color: var(--ink-soft);
	}
	/* Message text on the left (always inside one wrapper span so the flex
	   layout can't split it), the Skip/Share button on the right */
	.bar.status {
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
		min-height: 2.4em;
	}
	.bar.status:empty {
		display: none;
	}
	/* The hint button is created from the script, so it needs :global() too;
	   styled like the site's links */
	.bar.status :global(.hint) {
		padding: 0;
		background: none;
		border: none;
		font: inherit;
		color: var(--sky);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		cursor: pointer;
	}
	.bar.status :global(.hint:hover) {
		color: var(--sky-deep);
		background: var(--sky-tint);
	}
	/* Every shape name the quiz renders — the prompt, the wrong-guess names,
	   and the tooltip — follows the Font picker's choice; the script sets the
	   custom property on the element (name elements are script-created, so
	   the strong needs :global()) */
	.bar.status :global(strong),
	.name-tip {
		font-family: var(--name-font, inherit);
	}
	.picker,
	.font-picker,
	.find,
	.start,
	.progress-btn,
	.dialog-actions button,
	.bar.status :global(.skip),
	.bar.status :global(.share) {
		font: inherit;
		color: inherit;
		background: none;
		border: 1px solid var(--line);
		border-radius: 6px;
		padding: 0.2em 0.6em;
	}
	.start,
	.progress-btn {
		margin-left: auto;
		cursor: pointer;
		white-space: nowrap;
	}
	/* Start/Hands-Free on the right of the top bar; the transport trio swaps
	   in for them while hands-free plays, so only one group is ever visible */
	.top-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-left: auto;
	}
	.hf-transport {
		display: flex;
		gap: 0.4rem;
	}
	.hf-transport[hidden] {
		display: none;
	}
	.hf-btn,
	.hf-transport button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.28em 0.45em;
		background: none;
		border: 1px solid var(--line);
		border-radius: 6px;
		color: inherit;
		cursor: pointer;
	}
	/* No display on the svgs themselves: the buttons are flex containers (so
	   the icons are blockified anyway), and a display here would outweigh the
	   pause/play swap rules below once Astro's scoping attributes pile onto
	   every selector */
	.hf-btn svg,
	.hf-transport button svg {
		width: 1.1em;
		height: 1.1em;
	}
	.hf-btn:hover:not(:disabled),
	.hf-transport button:hover {
		border-color: var(--sky-line);
	}
	.hf-btn:disabled {
		opacity: 0.5;
		cursor: default;
	}
	.hf-btn[hidden] {
		display: none;
	}
	/* The pause button carries both glyphs; the paused class picks one */
	.hf-pause .icon-play {
		display: none;
	}
	.hf-pause.paused .icon-pause {
		display: none;
	}
	.hf-pause.paused .icon-play {
		display: block;
	}
	.hf-controls {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.hf-controls[hidden] {
		display: none;
	}
	.hf-stepper {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hf-label {
		font-size: 0.72rem;
		color: var(--ink-soft);
	}
	.hf-row {
		display: flex;
		align-items: center;
	}
	.hf-dec,
	.hf-inc {
		padding: 0 0.35em;
		background: none;
		border: none;
		color: var(--ink-soft);
		font: inherit;
		font-size: 1.05rem;
		line-height: 1;
		cursor: pointer;
		user-select: none;
		-webkit-user-select: none;
		touch-action: manipulation;
	}
	.hf-dec:hover,
	.hf-inc:hover {
		color: var(--sky-deep);
	}
	.hf-value {
		min-width: 2.4em;
		text-align: center;
		font-variant-numeric: tabular-nums;
	}
	/* The hands-free reveal fades in/out snappily whatever the zoom pace;
	   paths are Leaflet-created, so they need :global() */
	map-quiz :global(path.hf-reveal) {
		opacity: 0;
		transition: opacity 0.25s ease;
	}
	map-quiz :global(path.hf-reveal.hf-on) {
		opacity: 1;
	}
	/* The skip and share buttons are created from the script, so they need
	   :global() */
	.bar.status :global(.skip),
	.bar.status :global(.share) {
		cursor: pointer;
	}
	.start:hover:not(:disabled),
	.progress-btn:hover,
	.dialog-actions button:hover,
	.bar.status :global(.skip:hover),
	.bar.status :global(.share:hover) {
		border-color: var(--sky-line);
	}
	.start:disabled {
		opacity: 0.5;
	}
	.overlay {
		position: absolute;
		inset: 0;
		z-index: 1100; /* above Leaflet's controls (z-index 1000) */
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		background: rgb(28 27 24 / 0.35);
	}
	.overlay[hidden] {
		display: none;
	}
	.dialog {
		display: flex;
		flex-direction: column;
		max-width: min(33rem, 100%);
		max-height: 100%;
		padding: 0.9rem 1.1rem;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 10px 30px rgb(28 27 24 / 0.25);
		font-size: 0.9rem;
	}
	.dialog-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.6rem;
	}
	.close {
		padding: 0 0.2em;
		background: none;
		border: none;
		color: var(--ink-soft);
		font-size: 1.1rem;
		cursor: pointer;
	}
	.close:hover {
		color: var(--ink);
	}
	.table-wrap {
		overflow-y: auto;
		scrollbar-gutter: stable;
	}
	/* Table rows/cells and the toggle icons are created from the script, so
	   they miss Astro's scoping attribute and need :global() to match */
	.progress-table {
		border-collapse: collapse;
		font-size: 0.85rem;
	}
	.progress-table :global(th),
	.progress-table :global(td) {
		padding: 0.25em 0.7em;
	}
	.progress-table :global(thead th) {
		position: sticky;
		top: 0;
		background: var(--paper);
		color: var(--ink-soft);
		font-weight: 600;
	}
	.progress-table :global(tbody th) {
		font-weight: 400;
		text-align: left;
		white-space: nowrap;
	}
	.progress-table :global(td) {
		min-width: 4.2em;
		border: 1px solid var(--line);
		text-align: center;
	}
	.progress-table :global(tr.group td) {
		border: none;
		padding-top: 0.9em;
		color: var(--ink-soft);
		font-size: 0.75rem;
		text-align: left;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.progress-table :global(td.done) {
		background: #dcf2e3;
		color: #15803d;
	}
	.progress-table :global(td.tried) {
		background: #fdf1cc;
		color: #854d0e;
	}
	map-quiz :global(svg.icon) {
		width: 1.05em;
		height: 1.05em;
		vertical-align: -0.15em;
	}
	/* Condense the progress dialog on phones: tighter padding, narrower
	   cells, and wrapping row labels so the matrix never overflows x */
	@media (max-width: 480px) {
		.overlay {
			padding: 0.5rem;
		}
		.dialog {
			padding: 0.7rem 0.8rem;
		}
		.progress-table {
			font-size: 0.78rem;
		}
		.progress-table :global(th),
		.progress-table :global(td) {
			padding: 0.25em 0.4em;
		}
		.progress-table :global(tbody th) {
			white-space: normal;
		}
		.progress-table :global(td) {
			min-width: 3em;
		}
	}
	.confirm-overlay p {
		margin: 0 0 0.7rem;
	}
	.dont-ask {
		display: flex;
		align-items: center;
		gap: 0.4em;
		color: var(--ink-soft);
	}
	.dialog-actions {
		display: flex;
		justify-content: flex-end;
		gap: 0.6rem;
		margin-top: 1rem;
	}
	.dialog-actions button {
		cursor: pointer;
	}
	.options label {
		display: flex;
		align-items: center;
		gap: 0.35em;
		cursor: pointer;
	}
	/* The script hides bar controls via the hidden attribute (Find during
	   quizzes, the toggles during hands-free); the display rules above would
	   silently win without this */
	.options label[hidden] {
		display: none;
	}
</style>
