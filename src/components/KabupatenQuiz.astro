---
// Interactive find-on-map quiz over Indonesia's kabupaten, replicating the
// helloquiz.app "Indonesia Kabupaten Geoguessr only" quiz (405 shapes, GADM
// boundaries). Thin wrapper over MapQuizShell — the behavior lives in
// map-quiz.ts with the "kabupaten" definition from map-quiz-defs.ts, and the
// geometry in /data/kabupaten.json (regenerate with
// scripts/kabupaten-data.mjs).
//
// scope="province" | "region" — dropdown to pick a province / region group
// scope="all"                 — the full 399-kabupaten map, no dropdown
// initial                     — dropdown preselection (province name or region key)

import MapQuizShell from './MapQuizShell.astro';

interface Props {
	scope: 'province' | 'region' | 'all';
	initial?: string;
}

const { scope, initial } = Astro.props;
---

<MapQuizShell
	quiz="kabupaten"
	scope={scope}
	initial={initial}
	pickerLabel={scope !== 'all' ? `Choose a ${scope}` : undefined}
	labelsToggle
/>
