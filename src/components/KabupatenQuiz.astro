---
// Interactive find-on-map quiz over Indonesia's kabupaten, replicating the
// helloquiz.app "Indonesia Kabupaten Geoguessr only" quiz (405 shapes, GADM
// boundaries). Geometry loads once per page from /data/kabupaten.json
// (regenerate with scripts/kabupaten-data.mjs) and each instance initializes
// lazily when scrolled into view.
//
// scope="province" | "region" — dropdown to pick a province / region group
// scope="all"                 — the full 399-kabupaten map, no dropdown
// initial                     — dropdown preselection (province name or region key)

interface Props {
	scope: 'province' | 'region' | 'all';
	initial?: string;
}

const { scope, initial } = Astro.props;
---

<kabupaten-quiz data-scope={scope} data-initial={initial}>
	<div class="bar top">
		{scope !== 'all' && <select class="picker" aria-label={`Choose a ${scope}`}></select>}
		<button class="start" disabled>Start Quiz</button>
	</div>
	<div class="bar status" aria-live="polite">loading map…</div>
	<div class="map-wrap">
		<div class="map"></div>
		<div class="name-tip" hidden></div>
		<div class="overlay progress-overlay" hidden>
			<div class="dialog" role="dialog" aria-modal="true" aria-label="Progress">
				<div class="dialog-head">
					<strong>Progress</strong>
					<button class="close" aria-label="Close">✕</button>
				</div>
				<div class="table-wrap">
					<table class="progress-table"></table>
				</div>
			</div>
		</div>
		<div class="overlay confirm-overlay" hidden>
			<div class="dialog" role="dialog" aria-modal="true" aria-label="Confirm map option change">
				<p>Changing map options voids progress tracking for this quiz run.</p>
				<label class="dont-ask"><input type="checkbox" class="dont-ask-box" /> Don't ask me again</label>
				<div class="dialog-actions">
					<button class="cancel">Cancel</button>
					<button class="confirm">Continue</button>
				</div>
			</div>
		</div>
	</div>
	<div class="bar options">
		<label><input type="checkbox" class="borders" checked /> Borders</label>
		<label><input type="checkbox" class="labels" /> Labels</label>
		<button class="progress-btn">View Progress</button>
	</div>
</kabupaten-quiz>

<script>
	import L from 'leaflet';
	import 'leaflet/dist/leaflet.css';
	import type { Feature, MultiPolygon, Polygon } from 'geojson';

	type KabFeature = Feature<Polygon | MultiPolygon, { name: string; province: string }>;

	// The basemap tiles helloquiz uses: Google's roadmap endpoint, in a labeled
	// and a label-free variant (the second styles all label elements off).
	const TILES_LABELS =
		'https://www.google.com/maps/vt?pb=!1m7!8m6!1m3!1i{z}!2i{x}!3i{y}!2i9!3x1!2m2!1e0!2sm!3m3!2sen!3suk!5e18!4e0!5m4!1e0!8m2!1e1!1e1!6m6!1e12!2i2!11e0!39b0!44e0!50e0';
	const TILES_NO_LABELS =
		'https://www.google.com/maps/vt?pb=!1m5!1m4!1i{z}!2i{x}!3i{y}!4i256!2m2!1e0!2sm!3m17!2sen!3sUK!5e18!12m4!1e68!2m2!1sset!2sRoadmap!12m3!1e37!2m1!1ssmartmaps!12m4!1e26!2m2!1sstyles!2ss.e:l%7Cp.v:off,s.t:1%7Cs.e:g.s%7Cp.v:off!5m1!5f1';
	const ATTRIBUTION =
		'Imagery © Google · Boundaries © <a href="https://gadm.org">GADM</a> via <a href="https://helloquiz.app">helloquiz</a>';

	// Region groupings for scope="region" and the optgroups of the province
	// picker. Both pickers list entries in this order: regions run
	// Java → Nusas → Sulawesi → Kalimantan → Sumatra, and provinces sweep each
	// region naturally (west-to-east on Java and the Nusas,
	// southeast-to-southwest-to-north on Sulawesi, northeast-to-west on
	// Kalimantan, south-to-north on Sumatra).
	const REGIONS: Record<string, { label: string; provinces: string[] }> = {
		java: {
			label: 'Java',
			provinces: [
				'Banten',
				'DKI Jakarta',
				'Jawa Barat',
				'Jawa Tengah',
				'Daerah Istimewa Yogyakarta',
				'Jawa Timur',
			],
		},
		nusas: {
			label: 'Bali & Nusa Tenggara',
			provinces: ['Bali', 'Nusa Tenggara Barat', 'Nusa Tenggara Timur'],
		},
		sulawesi: {
			label: 'Sulawesi & Maluku Utara',
			provinces: [
				'Sulawesi Tenggara',
				'Sulawesi Selatan',
				'Sulawesi Barat',
				'Sulawesi Tengah',
				'Gorontalo',
				'Sulawesi Utara',
				'Maluku Utara',
			],
		},
		kalimantan: {
			label: 'Kalimantan',
			provinces: [
				'Kalimantan Utara',
				'Kalimantan Timur',
				'Kalimantan Selatan',
				'Kalimantan Tengah',
				'Kalimantan Barat',
			],
		},
		sumatra: {
			label: 'Sumatra',
			provinces: [
				'Lampung',
				'Kepulauan Bangka Belitung',
				'Sumatera Selatan',
				'Bengkulu',
				'Jambi',
				'Riau',
				'Kepulauan Riau',
				'Sumatera Barat',
				'Sumatera Utara',
				'Aceh',
			],
		},
	};

	const STROKE = '#075985';
	const FLASH_MS = 700;

	// Progress tracking: the three drill stages from the post, keyed by the
	// Borders/Labels toggle combination (both-on is not a tracked stage).
	// Each cell keeps the best first-try score of any finished run whose
	// toggles stayed locked to that combination; best === total marks it done.
	type ModeKey = 'borders' | 'neither' | 'labels';
	type CellRecord = { best: number; total: number };
	type ProgressStore = Record<string, Partial<Record<ModeKey, CellRecord>>>;

	const MODES: { key: ModeKey; label: string }[] = [
		{ key: 'borders', label: 'Borders' },
		{ key: 'neither', label: 'Neither' },
		{ key: 'labels', label: 'Labels' },
	];

	// Inline icons for the toggles and the progress-table columns: a dashed
	// circle for borders, a map pin for labels, an X for neither
	const icon = (paths: string) =>
		`<svg class="icon" viewBox="0 0 16 16" aria-hidden="true">${paths}</svg>`;
	const ICONS: Record<ModeKey, string> = {
		borders: icon(
			'<circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2.4 2.31"/>',
		),
		neither: icon(
			'<path d="M4 4l8 8M12 4l-8 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
		),
		labels: icon(
			'<path d="M8 1.5A4.5 4.5 0 0 0 3.5 6c0 3.2 4.5 8.5 4.5 8.5S12.5 9.2 12.5 6A4.5 4.5 0 0 0 8 1.5Z" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="6" r="1.6" fill="currentColor"/>',
		),
	};
	const modeFromToggles = (borders: boolean, labels: boolean): ModeKey | null =>
		labels ? (borders ? null : 'labels') : borders ? 'borders' : 'neither';

	const PROGRESS_KEY = 'kabupaten-progress';
	const SKIP_CONFIRM_KEY = 'kabupaten-skip-toggle-confirm';
	const uiKey = (scope: string) => `kabupaten-ui:${scope}`;

	const readStored = <T,>(key: string): T | null => {
		try {
			return JSON.parse(localStorage.getItem(key) ?? 'null');
		} catch {
			return null;
		}
	};
	const writeStored = (key: string, value: unknown) => {
		try {
			localStorage.setItem(key, JSON.stringify(value));
		} catch {
			// Private mode / quota: the quiz works, progress just doesn't persist
		}
	};

	let dataPromise: Promise<KabFeature[]> | null = null;
	const loadData = () =>
		(dataPromise ??= fetch('/data/kabupaten.json')
			.then((r) => r.json())
			.then((geojson) => geojson.features as KabFeature[]));

	const shuffle = <T,>(items: T[]) => {
		for (let i = items.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[items[i], items[j]] = [items[j], items[i]];
		}
		return items;
	};

	class KabupatenQuiz extends HTMLElement {
		map!: L.Map;
		geoLayer: L.GeoJSON | null = null;
		layers: { layer: L.Path; feature: KabFeature }[] = [];
		status!: HTMLElement;
		startButton!: HTMLButtonElement;
		bordersBox!: HTMLInputElement;
		labelsBox!: HTMLInputElement;
		picker: HTMLSelectElement | null = null;
		nameTip!: HTMLElement;
		progressOverlay!: HTMLElement;
		confirmOverlay!: HTMLElement;
		progressTable!: HTMLTableElement;
		dontAskBox!: HTMLInputElement;
		confirmResolve: ((confirmed: boolean) => void) | null = null;

		// Quiz state
		mode: 'explore' | 'quiz' = 'explore';
		queue: KabFeature[] = [];
		current: KabFeature | null = null;
		awaiting: 'answer' | 'confirm' = 'answer';
		missed = new Set<KabFeature>();
		firstTry = new Set<KabFeature>();
		// Post-quiz review tint per shape: green for first-try, red for missed
		review = new Map<KabFeature, string>();
		completed = 0;
		total = 0;
		revealed: { layer: L.Path; feature: KabFeature } | null = null;
		// Which progress cell this run counts toward once finished; a run is
		// voided (records nothing) when started on the untracked both-toggles-on
		// combo or when a toggle changes mid-run
		runMode: ModeKey | null = null;
		runVoided = true;
		runScopeKey = '';

		connectedCallback() {
			const observer = new IntersectionObserver(
				(entries) => {
					if (entries.some((entry) => entry.isIntersecting)) {
						observer.disconnect();
						this.init();
					}
				},
				{ rootMargin: '300px' },
			);
			observer.observe(this);
		}

		async init() {
			this.status = this.querySelector('.status')!;
			this.startButton = this.querySelector('.start')!;
			this.bordersBox = this.querySelector('.borders')!;
			this.labelsBox = this.querySelector('.labels')!;
			this.nameTip = this.querySelector('.name-tip')!;
			this.progressOverlay = this.querySelector('.progress-overlay')!;
			this.confirmOverlay = this.querySelector('.confirm-overlay')!;
			this.progressTable = this.querySelector('.progress-table')!;
			this.dontAskBox = this.querySelector('.dont-ask-box')!;
			const picker = (this.picker = this.querySelector<HTMLSelectElement>('.picker'));

			// Restore the selection and toggles this instance was last left on
			const savedUI = readStored<{ selection?: string; borders?: boolean; labels?: boolean }>(
				uiKey(this.dataset.scope!),
			);
			if (savedUI?.borders !== undefined) this.bordersBox.checked = savedUI.borders;
			if (savedUI?.labels !== undefined) this.labelsBox.checked = savedUI.labels;

			this.bordersBox.insertAdjacentHTML('afterend', ICONS.borders);
			this.labelsBox.insertAdjacentHTML('afterend', ICONS.labels);

			const features = await loadData();
			const provinces = new Set(features.map((f) => f.properties.province));

			this.map = L.map(this.querySelector<HTMLElement>('.map')!, {
				attributionControl: true,
				zoomSnap: 0.5,
				maxZoom: 15,
				minZoom: 3,
				fadeAnimation: false,
			});
			this.map.attributionControl.setPrefix(false);
			// The tip is anchored to a container point, so it goes stale as soon
			// as the view changes; hide it and let the next mousemove replace it
			this.map.on('movestart zoomstart', () => (this.nameTip.hidden = true));

			const labeled = L.tileLayer(TILES_LABELS, { attribution: ATTRIBUTION, maxZoom: 15 });
			const unlabeled = L.tileLayer(TILES_NO_LABELS, { attribution: ATTRIBUTION, maxZoom: 15 });
			(this.labelsBox.checked ? labeled : unlabeled).addTo(this.map);
			this.labelsBox.addEventListener('change', () =>
				this.toggleChanged(this.labelsBox, () => {
					this.map.removeLayer(this.labelsBox.checked ? unlabeled : labeled);
					this.map.addLayer(this.labelsBox.checked ? labeled : unlabeled);
				}),
			);

			this.bordersBox.addEventListener('change', () =>
				this.toggleChanged(this.bordersBox, () => this.restyleAll()),
			);

			const scopes = (): KabFeature[] => {
				if (!picker) return features;
				if (this.dataset.scope === 'province')
					return features.filter((f) => f.properties.province === picker.value);
				return features.filter((f) =>
					REGIONS[picker.value].provinces.includes(f.properties.province),
				);
			};

			if (picker) {
				if (this.dataset.scope === 'province') {
					for (const region of Object.values(REGIONS)) {
						const group = document.createElement('optgroup');
						group.label = region.label;
						for (const p of region.provinces) if (provinces.has(p)) group.append(new Option(p, p));
						picker.append(group);
					}
				} else {
					for (const [key, region] of Object.entries(REGIONS))
						picker.add(new Option(region.label, key));
				}
				const wanted = savedUI?.selection ?? this.dataset.initial;
				if (wanted && [...picker.options].some((option) => option.value === wanted))
					picker.value = wanted;
				picker.addEventListener('change', () => {
					this.persistUI();
					this.setScope(scopes());
				});
			}

			this.startButton.addEventListener('click', () => {
				if (this.mode === 'quiz') this.endQuiz();
				else this.startQuiz();
			});

			this.wireDialogs(provinces);

			this.setScope(scopes());
			this.startButton.disabled = false;
		}

		persistUI() {
			writeStored(uiKey(this.dataset.scope!), {
				selection: this.picker?.value,
				borders: this.bordersBox.checked,
				labels: this.labelsBox.checked,
			});
		}

		// Route toggle flips through the progress guard: during a quiz the first
		// flip voids the run's progress credit, so it asks first (unless the
		// user opted out of the prompt for good)
		toggleChanged(box: HTMLInputElement, apply: () => void) {
			if (this.mode === 'quiz' && !this.runVoided && !readStored(SKIP_CONFIRM_KEY)) {
				const wanted = box.checked;
				box.checked = !wanted;
				this.askConfirm().then((confirmed) => {
					if (!confirmed) return;
					if (this.dontAskBox.checked) writeStored(SKIP_CONFIRM_KEY, true);
					this.runVoided = true;
					box.checked = wanted;
					apply();
					this.persistUI();
				});
				return;
			}
			if (this.mode === 'quiz') this.runVoided = true;
			apply();
			this.persistUI();
		}

		// --- progress dialogs --------------------------------------------------

		wireDialogs(provinces: Set<string>) {
			this.querySelector('.progress-btn')!.addEventListener('click', () => {
				this.buildProgressTable(provinces);
				this.nameTip.hidden = true;
				this.progressOverlay.hidden = false;
				this.querySelector<HTMLButtonElement>('.close')!.focus();
			});
			this.querySelector('.close')!.addEventListener(
				'click',
				() => (this.progressOverlay.hidden = true),
			);
			this.progressOverlay.addEventListener('click', (e) => {
				if (e.target === this.progressOverlay) this.progressOverlay.hidden = true;
			});

			this.querySelector('.cancel')!.addEventListener('click', () => this.resolveConfirm(false));
			this.querySelector('.confirm')!.addEventListener('click', () => this.resolveConfirm(true));
			this.confirmOverlay.addEventListener('click', (e) => {
				if (e.target === this.confirmOverlay) this.resolveConfirm(false);
			});

			document.addEventListener('keydown', (e) => {
				if (e.key !== 'Escape') return;
				if (!this.confirmOverlay.hidden) this.resolveConfirm(false);
				else if (!this.progressOverlay.hidden) this.progressOverlay.hidden = true;
			});
		}

		askConfirm(): Promise<boolean> {
			this.dontAskBox.checked = false;
			this.progressOverlay.hidden = true;
			this.nameTip.hidden = true;
			this.confirmOverlay.hidden = false;
			this.querySelector<HTMLButtonElement>('.cancel')!.focus();
			return new Promise((resolve) => (this.confirmResolve = resolve));
		}

		resolveConfirm(confirmed: boolean) {
			this.confirmOverlay.hidden = true;
			this.confirmResolve?.(confirmed);
			this.confirmResolve = null;
		}

		scopeKey() {
			const scope = this.dataset.scope!;
			return scope === 'all' ? 'all' : `${scope}:${this.picker!.value}`;
		}

		// A finished run with its toggles locked to a tracked combo updates that
		// cell when it beats the stored best
		recordRun(score: number) {
			if (!this.runMode || this.runVoided) return;
			const store = readStored<ProgressStore>(PROGRESS_KEY) ?? {};
			const cells = (store[this.runScopeKey] ??= {});
			const prev = cells[this.runMode];
			if (!prev || score / this.total > prev.best / prev.total) {
				cells[this.runMode] = { best: score, total: this.total };
				writeStored(PROGRESS_KEY, store);
			}
		}

		buildProgressTable(provinces: Set<string>) {
			const store = readStored<ProgressStore>(PROGRESS_KEY) ?? {};
			this.progressTable.innerHTML = '';
			const head = this.progressTable.createTHead().insertRow();
			head.append(document.createElement('th'));
			for (const mode of MODES) {
				const th = document.createElement('th');
				th.innerHTML = ICONS[mode.key];
				th.title = mode.label;
				th.setAttribute('aria-label', mode.label);
				head.append(th);
			}

			const body = this.progressTable.createTBody();
			const addRow = (label: string, key: string) => {
				const row = body.insertRow();
				const rowHead = document.createElement('th');
				rowHead.scope = 'row';
				rowHead.textContent = label;
				row.append(rowHead);
				for (const mode of MODES) {
					const cell = row.insertCell();
					const record = store[key]?.[mode.key];
					if (!record) continue;
					if (record.best >= record.total) {
						cell.className = 'done';
						cell.textContent = '✓';
					} else {
						cell.className = 'tried';
						cell.textContent = `${Math.floor((record.best / record.total) * 100)}%`;
					}
				}
			};

			if (this.dataset.scope === 'all') addRow('All Indonesia', 'all');
			else if (this.dataset.scope === 'region')
				for (const [key, region] of Object.entries(REGIONS)) addRow(region.label, `region:${key}`);
			else
				for (const region of Object.values(REGIONS)) {
					const groupRow = body.insertRow();
					groupRow.className = 'group';
					const groupCell = groupRow.insertCell();
					groupCell.colSpan = MODES.length + 1;
					groupCell.textContent = region.label;
					for (const p of region.provinces) if (provinces.has(p)) addRow(p, `province:${p}`);
				}
		}

		setScope(features: KabFeature[]) {
			this.endQuiz(true);
			this.review.clear();
			this.geoLayer?.remove();
			this.layers = [];
			this.geoLayer = L.geoJSON(features, {
				style: () => this.styleFor(null),
				onEachFeature: (feature: KabFeature, layer) => {
					const path = layer as L.Path;
					this.layers.push({ layer: path, feature });
					layer.on('mouseover', () => this.hover(path, feature, true));
					layer.on('mousemove', (e) => this.moveTip(e as L.LeafletMouseEvent, feature));
					layer.on('mouseout', () => this.hover(path, feature, false));
					layer.on('click', (e) => this.clicked(path, feature, e as L.LeafletMouseEvent));
				},
			}).addTo(this.map);
			this.map.fitBounds(this.geoLayer.getBounds().pad(0.05));
			this.status.textContent = '';
		}

		// --- styling ---------------------------------------------------------

		styleFor(feature: KabFeature, flash: string | null = null): L.PathOptions {
			const borders = this.bordersBox.checked;
			const tint = flash ?? this.review.get(feature) ?? null;
			return {
				color: STROKE,
				weight: 1.2,
				opacity: borders ? 0.9 : 0,
				fillColor: tint ?? '#000',
				// Transparent black tint alongside borders; with borders off the
				// fill stays invisible but keeps shapes clickable. Flash and
				// review colors show regardless of the Borders toggle.
				fillOpacity: flash ? 0.5 : tint ? 0.35 : borders ? 0.12 : 0,
				fill: true,
			};
		}

		restyleAll() {
			for (const { layer, feature } of this.layers) {
				const isRevealed = this.revealed?.layer === layer;
				layer.setStyle(this.styleFor(feature, isRevealed ? 'gold' : null));
			}
		}

		flash(layer: L.Path, feature: KabFeature, color: string) {
			layer.setStyle(this.styleFor(feature, color));
			setTimeout(() => {
				if (this.revealed?.layer !== layer) layer.setStyle(this.styleFor(feature));
			}, FLASH_MS);
		}

		hover(layer: L.Path, feature: KabFeature, over: boolean) {
			if (!over) this.nameTip.hidden = true;
			if (this.revealed?.layer === layer) return;
			// No hover highlight with borders off — it would give shapes away
			// during the no-borders drill stage
			if (over && this.bordersBox.checked) {
				const style = this.styleFor(feature);
				layer.setStyle({ ...style, fillOpacity: (style.fillOpacity ?? 0) + 0.16 });
			} else layer.setStyle(this.styleFor(feature));
		}

		// Hand-rolled name tooltip: Leaflet's bindTooltip leaks focus handlers
		// when unbound (Leaflet #8297), and we'd be rebinding every quiz start
		showTip(event: L.LeafletMouseEvent, name: string) {
			this.nameTip.textContent = name;
			this.nameTip.style.left = `${event.containerPoint.x + 14}px`;
			this.nameTip.style.top = `${event.containerPoint.y + 14}px`;
			this.nameTip.hidden = false;
		}

		moveTip(event: L.LeafletMouseEvent, feature: KabFeature) {
			if (this.mode !== 'explore') {
				this.nameTip.hidden = true;
				return;
			}
			this.showTip(event, feature.properties.name);
		}

		// --- quiz ------------------------------------------------------------

		startQuiz() {
			this.mode = 'quiz';
			this.runMode = modeFromToggles(this.bordersBox.checked, this.labelsBox.checked);
			this.runVoided = this.runMode === null;
			this.runScopeKey = this.scopeKey();
			this.queue = shuffle(this.layers.map((entry) => entry.feature));
			this.total = this.queue.length;
			this.missed.clear();
			this.firstTry.clear();
			this.review.clear();
			this.completed = 0;
			this.revealed = null;
			this.nameTip.hidden = true;
			this.startButton.textContent = 'End Quiz';
			this.restyleAll();
			this.nextQuestion();
		}

		endQuiz(silent = false) {
			if (this.mode === 'quiz') {
				// Review tint: what you got on the first try vs. what you missed
				for (const feature of this.firstTry) this.review.set(feature, '#16a34a');
				for (const feature of this.missed) this.review.set(feature, '#dc2626');
			}
			this.mode = 'explore';
			this.current = null;
			this.revealed = null;
			this.startButton.textContent = 'Start Quiz';
			if (this.layers.length) this.restyleAll();
			if (!silent) this.status.textContent = '';
		}

		nextQuestion() {
			this.revealed = null;
			this.awaiting = 'answer';
			const next = this.queue.shift();
			if (!next) {
				const score = this.total - this.missed.size;
				this.recordRun(score);
				this.endQuiz(true);
				this.status.textContent = `Final score: ${score}/${this.total} on the first try.`;
				return;
			}
			this.current = next;
			this.showPrompt();
		}

		showPrompt() {
			this.status.innerHTML = '';
			this.status.append('Find ');
			const name = document.createElement('strong');
			name.textContent = this.current!.properties.name;
			this.status.append(name, `. · ${this.completed}/${this.total}`);
		}

		clicked(layer: L.Path, feature: KabFeature, event: L.LeafletMouseEvent) {
			if (this.mode !== 'quiz' || !this.current) return;

			if (this.awaiting === 'confirm') {
				if (this.revealed?.feature === feature) {
					const target = this.revealed;
					this.revealed = null;
					this.flash(target.layer, target.feature, 'gold');
					this.queue.push(this.current);
					this.nextQuestion();
				} else {
					// Let the player probe adjacent shapes for their names while
					// the answer is highlighted
					this.showTip(event, feature.properties.name);
				}
				return;
			}

			if (feature.properties.name === this.current.properties.name) {
				if (!this.missed.has(this.current)) this.firstTry.add(this.current);
				this.flash(layer, feature, '#16a34a');
				this.completed++;
				this.nextQuestion();
			} else {
				this.missed.add(this.current);
				this.flash(layer, feature, '#dc2626');
				const target = this.layers.find((entry) => entry.feature === this.current)!;
				this.revealed = target;
				target.layer.setStyle(this.styleFor(target.feature, 'gold'));
				this.awaiting = 'confirm';
				this.status.innerHTML = '';
				const guess = document.createElement('strong');
				guess.textContent = feature.properties.name;
				const name = document.createElement('strong');
				name.textContent = this.current.properties.name;
				this.status.append('That was ', guess, '. ', name, ' is highlighted. Click it to continue.');
			}
		}
	}

	customElements.define('kabupaten-quiz', KabupatenQuiz);
</script>

