---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import logo from '../images/dan-dangond-logo.png';
import dan from '../images/dan.jpeg';
---

<Layout title="Home" active="home" showNavLogo={false}>
	<div class="hero">
		<Image class="hero-logo" src={logo} alt="Dan Dangond" width={440} densities={[1, 2]} />
		<Image class="hero-photo" src={dan} alt="Photo of Daniel Dangond" width={150} height={150} />
	</div>

	<p class="intro">
		Hi, I'm Dan! I'm a software engineer and a big fan of building my own tools. If you're here
		because you want to hire me, check out <a href="/dev">/dev</a> for a taste of what I build in
		my spare time. If you just want to see fun things I've made, you can't go wrong with any of
		<a href="/dev">/dev</a>, <a href="/games">/games</a>, and <a href="/3d">/3d</a>.
	</p>

	<div class="facts">
		<div class="fact"><span class="fact-label">Name:</span> Daniel Dangond</div>
		<div class="fact"><span class="fact-label">Online aliases:</span> Guatapuri, Onward! Games</div>
		<div class="fact">
			<span class="fact-label">Hobbies:</span> Writing software, playing and making games, D&D,
			piano, digital art, photography
		</div>
	</div>

	<h2 class="section">Work experience</h2>
	<ul class="entries">
		<li>
			<a href="https://pulley.com/">Senior Software Engineer at Pulley</a>
			<span class="when">January 2025 – present</span>
		</li>
		<li>
			<a href="https://www.ptc.com/en/about/reality-lab">Senior Innovation Engineer at the PTC Reality Lab</a>
			<span class="when">January 2021 – December 2024</span>
		</li>
		<li>
			<a href="https://credentials.mit.edu/certificate/9af1894af5f35a7bb8f7dcd45db591b7">
				B.S. Computer Science and Engineering + B.S. Comparative Media Studies
			</a>
			<span class="when">MIT '21</span>
		</li>
	</ul>

	<h2 class="section">Side stuff</h2>
	<ul class="entries">
		<li>
			<a href="https://loresage.com/">Creator of Lore Sage</a>
			<span class="when">March 2023 – July 2023</span>
		</li>
		<li>
			<a href="https://onward.games/">Creator of Onward! Games</a>
			<span class="when">July 2022 – present</span>
		</li>
	</ul>

	<h2 class="section">Things I've made</h2>
	<div class="collections">
		<a class="collection" href="/dev">Dev projects <span class="arrow">→</span></a>
		<a class="collection" href="/games">Games <span class="arrow">→</span></a>
		<a class="collection" href="/3d">3D animations <span class="arrow">→</span></a>
	</div>
</Layout>

<style>
	.hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		margin: 2rem 0 2.5rem;
	}
	.hero-logo {
		width: min(440px, 60vw);
		height: auto;
	}
	.hero-photo {
		border-radius: 8px;
		border: 1px solid var(--line);
		transform: rotate(2deg);
		box-shadow: 2px 3px 0 var(--line);
	}
	.facts {
		margin: 1.5rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.fact-label {
		font-weight: 600;
	}
	.entries {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.when {
		color: var(--ink-soft);
		font-size: 0.85rem;
		margin-left: 0.4em;
		white-space: nowrap;
	}
	.collections {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.collection {
		display: flex;
		justify-content: space-between;
		align-items: center;
		text-decoration: none;
		font-weight: 500;
		padding: 0.7em 1em;
		border: 1.5px dashed var(--sky-line);
		border-radius: 6px;
	}
	.collection:hover {
		border-style: solid;
		background: var(--sky-tint);
	}
	.arrow {
		transition: transform 0.15s;
	}
	.collection:hover .arrow {
		transform: translateX(4px);
	}
	@media (max-width: 550px) {
		.hero {
			flex-direction: column;
			align-items: flex-start;
			gap: 1.5rem;
		}
	}
</style>
